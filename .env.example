# ==== Supabase ====
# Dashboard → Settings → API keys
NEXT_PUBLIC_SUPABASE_URL=****
# Publishable key (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=****
# Secret key (sb_secret_...): SOLO servidor. Salta la RLS — nunca en el cliente.
# Preferir sb_secret_ sobre la legacy service_role (rotación/revocación individual).
SUPABASE_SECRET_KEY=****

# ==== Gemini (Developer API, NO Vertex) ====
# https://aistudio.google.com/apikey
GEMINI_API_KEY=****
GEMINI_MODEL=gemini-3.5-flash

# ==== Piloto ====
# El límite diario de chat turns vive en la tabla app_settings
# (clave max_chat_turns_per_user_per_day), no en variables de entorno.
# Gate de consentimiento: fijar cuando exista la política publicada.
# PRIVACY_POLICY_VERSION=v1
